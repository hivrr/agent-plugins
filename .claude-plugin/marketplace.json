{
  "name": "hivrr-claude-plugin",
  "owner": { "name": "retroboot" },
  "metadata": {
    "description": "Hivrr Claude Plugin — Skills and commands for implementation, brainstorming, planning, and code review",
    "version": "2.1.0"
  },
  "plugins": [
    {
      "name": "hivrr-skills",
      "description": "Implementation and code workflow skills — audits, debugging, PR workflows, wave execution",
      "source": "./",
      "strict": false,
      "skills": [
        "./skill/audit",
        "./skill/audit-accessibility",
        "./skill/audit-performance",
        "./skill/audit-security",
        "./skill/audit-tech-debt",
        "./skill/core",
        "./skill/debug",
        "./skill/merge-pr",
        "./skill/wave",
        "./skill/work-issue",
        "./skill/work-pr"
      ],
      "commands": [
        "./command/audit.md",
        "./command/debug.md",
        "./command/merge-pr.md",
        "./command/work-issue.md",
        "./command/work-pr.md"
      ]
    },
    {
      "name": "hivrr-brainstorm",
      "description": "Interactive brainstorming for product ideation and refinement",
      "source": "./",
      "strict": false,
      "skills": ["./skill/brainstorm"],
      "commands": ["./command/brainstorm.md"]
    },
    {
      "name": "hivrr-planning",
      "description": "Project planning and task decomposition",
      "source": "./",
      "strict": false,
      "skills": ["./skill/planning"],
      "commands": ["./command/planning.md"]
    },
    {
      "name": "hivrr-review",
      "description": "Pull request code review — fetches diff, analyzes, posts structured BLOCKER/REQUIRED/DEFERRED comment",
      "source": "./",
      "strict": false,
      "skills": ["./skill/review-pr"],
      "commands": ["./command/review-pr.md"]
    },
    {
      "name": "hivrr-manager",
      "description": "Manager utility skills — score, group, and diagnose issues for automated work allocation",
      "source": "./",
      "strict": false,
      "skills": [
        "./skill/score-issues",
        "./skill/group-issues",
        "./skill/diagnose-failure"
      ],
      "commands": [
        "./command/score-issues.md",
        "./command/group-issues.md",
        "./command/diagnose-failure.md"
      ]
    }
  ]
}
